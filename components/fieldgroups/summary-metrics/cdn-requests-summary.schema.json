  "$id": "https://ns.adobe.com/xdm/fieldgroups/cdn-requests-summary",
  "$schema": "http://json-schema.org/draft-06/schema#",
  "title": "CDN Requests Summary",
  "type": "object",
  "meta:extensible": true,
  "meta:abstract": true,
  "meta:tags": {
    "industry": ["all"]
  },
  "meta:intendedToExtend": ["https://ns.adobe.com/xdm/classes/summarymetrics"],
  "description": "Aggregate CDN requests properties and metrics including bot classification, HTTP request patterns, response codes, and request latencies",
  "definitions": {
    "cdnRequestsSummary": {
      "properties": {
        "xdm:cdn": {
          "title": "CDN Requests Summary",
          "type": "object",
          "description": "Summary of CDN requests with properties and metrics",
          "properties": {
            "xdm:host": {
              "title": "Host",
              "type": "string",
              "description": "Requested host/domain"
            },
            "xdm:url": {
              "title": "URL",
              "type": "string",
              "description": "URL path excluding domain"
            },
            "xdm:botType": {
              "title": "Bot Type",
              "type": "string",
              "description": "Bot type classification"
            },
            "xdm:userAgent": {
              "title": "User Agent",
              "type": "string",
              "description": "Complete user agent string sent by the client"
            },
            "xdm:cdnProvider": {
              "title": "CDN Provider",
              "type": "string",
              "description": "CDN service provider identifier for source lineage",
              "meta:enum": {
                "fastly": "Fastly",
                "akamai": "Akamai",
                "cloudfront": "Amazon CloudFront",
                "cloudflare": "Cloudflare",
                "frontdoor": "Azure Front Door",
                "googlecdn": "Google Cloud CDN",
                "bunnycdn": "BunnyCDN",
                "gcore": "Gcore"
              }
            },
            "xdm:status": {
              "title": "HTTP Status",
              "type": "integer",
              "description": "HTTP response status code",
              "minimum": 100,
              "maximum": 599
            },
            "xdm:referer": {
              "title": "Referer",
              "type": "string",
              "description": "External referer domain"
            },
            "xdm:xForwardedHost": {
              "title": "X-Forwarded-Host",
              "type": "string",
              "description": "X-Forwarded-Host header value from CDN or proxy"
            },
            "xdm:timeToFirstByte": {
              "title": "Time to First Byte",
              "type": "number",
              "description": "Latency metric in milliseconds"
            },
            "xdm:requests": {
              "title": "Request Count",
              "type": "integer",
              "description": "Total number of aggregated requests",
              "minimum": 1
            }
          }
        }
      }
    }
  },
  "allOf": [
    {
      "$ref": "#/definitions/cdnRequestsSummary"
    }
  ],
  "meta:status": "experimental"
}