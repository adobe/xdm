  "$id": "https://ns.adobe.com/xdm/mixins/events/conversation-concierge-event",
  "$schema": "http://json-schema.org/draft-06/schema#",
  "title": "Conversation Concierge event (session expiration)",
  "type": "object",
  "meta:tags": {
    "b2bSchema": true
  },
  "meta:conditionalField": "xdm:eventType",
  "meta:conditionalValue": "session_expiration",
  "meta:intendedToExtend": [
    "https://ns.adobe.com/xdm/context/experienceevent"
  ],
  "description": "Emitted when a Brand Concierge conversation session expires, including concierge identity, timing, duration, and outcome status.",
  "definitions": {
    "conversationconciergeevent": {
      "properties": {
        "xdm:engagement": {
          "title": "Engagement",
          "type": "object",
          "properties": {
            "xdm:conversationConciergeEvent": {
              "title": "Conversation Concierge event",
              "type": "object",
              "properties": {
                "xdm:conciergeDetails": {
                  "title": "Concierge Details",
                  "type": "object",
                  "properties": {
                    "xdm:conciergeName": {
                      "title": "Concierge Name",
                      "type": "string",
                      "description": "Display name of the Concierge."
                    }
                  }
                },
                "xdm:sessionExpirationDetails": {
                  "title": "Session expiration details",
                  "type": "object",
                  "properties": {
                    "xdm:createdAt": {
                      "title": "Created At",
                      "type": "string",
                      "format": "date-time",
                      "description": "ISO 8601 timestamp for when the session or conversation context was created."
                    },
                    "xdm:duration": {
                      "title": "Duration",
                      "type": "string",
                      "description": "Elapsed duration as an ISO 8601 duration (for example PT15M for 15 minutes)."
                    },
                    "xdm:conversationStatus": {
                      "title": "Conversation Status",
                      "type": "string",
                      "description": "Outcome of the conversation at session expiration.",
                      "enum": ["INITIATED", "DROPPED", "COMPLETED"],
                      "meta:enum": {
                        "INITIATED": "Conversation was initiated",
                        "DROPPED": "Visitor dropped off before completion",
                        "COMPLETED": "Conversation completed"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "allOf": [
    {
      "$ref": "#/definitions/conversationconciergeevent"
    }
  ],
  "meta:status": "experimental",
  "meta:createdDate": "2026-04-07"
}
