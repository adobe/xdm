  "$schema": "http://json-schema.org/draft-06/schema#",
  "$id": "https://ns.adobe.com/xdm/datatypes/paid-media-targeting",
  "title": "Paid Media Targeting",
  "type": "object",
  "description": "Data type representing targeting specifications for paid media campaigns",
  "definitions": {
    "targeting": {
      "properties": {
        "xdm:geoTargeting": {
          "type": "object",
          "title": "Geographic Targeting",
          "description": "Geographic targeting specifications. Values are normalized across ad networks: ISO codes for countries and regions, canonical names for cities. Network-native geo IDs (e.g. Google Ads geoTargetConstant criterion IDs, Meta adgeolocation keys) belong in `xdm:networkGeoTargets` for round-trip to the source API.",
          "properties": {
            "xdm:countries": {
              "type": "array",
              "title": "Countries",
              "description": "Targeted countries. New integrations SHOULD emit ISO 3166-1 alpha-2 codes (e.g. US, CA, GB, DE) to enable cross-network analytics in downstream datasets. Free-form country names are accepted for backwards compatibility but are deprecated and may be rejected once this datatype transitions from experimental to stable.",
              "items": {
                "type": "string"
              }
            },
            "xdm:regions": {
              "type": "array",
              "title": "Regions/States",
              "description": "Targeted regions or states. New integrations SHOULD emit ISO 3166-2 codes (e.g. US-CA, DE-BB, JP-13) matching the convention in `components/datatypes/demographic/geo.schema.json` stateProvince. Free-form region/state names are accepted for backwards compatibility but are deprecated and may be rejected once this datatype transitions from experimental to stable.",
              "items": {
                "type": "string",
                "examples": ["US-CA", "DE-BB", "JP-13"]
              }
            },
            "xdm:cities": {
              "type": "array",
              "title": "Cities",
              "description": "Targeted cities as canonical city names. ISO/UN-LOCODE is sparse for cities, so canonical names are used; callers should scope cities by the entries in `xdm:regions` and `xdm:countries` to disambiguate (e.g. \"Springfield\" under US-IL vs US-MA).",
              "items": {
                "type": "string"
              }
            },
            "xdm:postalCodes": {
              "type": "array",
              "title": "Postal Codes",
              "description": "Targeted postal codes. Format varies by country; callers should scope postal codes by the entries in `xdm:countries`.",
              "items": {
                "type": "string"
              }
            },
            "xdm:radius": {
              "type": "object",
              "title": "Radius Targeting",
              "description": "Location radius targeting",
              "properties": {
                "xdm:latitude": {
                  "type": "number",
                  "title": "Latitude"
                },
                "xdm:longitude": {
                  "type": "number",
                  "title": "Longitude"
                },
                "xdm:radiusKm": {
                  "type": "number",
                  "title": "Radius (km)",
                  "description": "Radius in kilometers"
                }
              }
            },
            "xdm:networkGeoTargets": {
              "type": "array",
              "title": "Network-Native Geo Targets",
              "description": "Platform-native geo target references preserved alongside the normalized values in `xdm:countries`, `xdm:regions`, `xdm:cities`, and `xdm:postalCodes`. Use this to round-trip geo selections back to the source ad network API (e.g. Google Ads `geoTargetConstants/{id}`, Meta adgeolocation `key`) without losing fidelity. The `xdm:adNetwork` on the parent paid-media object identifies which network these IDs belong to.",
              "items": {
                "type": "object",
                "properties": {
                  "xdm:geoType": {
                    "type": "string",
                    "title": "Geo Type",
                    "description": "The kind of geographic entity this network-native ID refers to.",
                    "enum": [
                      "country",
                      "region",
                      "city",
                      "postal_code",
                      "dma",
                      "msa",
                      "neighborhood",
                      "other"
                    ],
                    "meta:enum": {
                      "country": "Country",
                      "region": "Region, state, or province",
                      "city": "City",
                      "postal_code": "Postal code",
                      "dma": "Designated market area (Nielsen)",
                      "msa": "Metropolitan statistical area",
                      "neighborhood": "Neighborhood or sub-city area",
                      "other": "Other geographic entity type"
                    }
                  },
                  "xdm:networkID": {
                    "type": "string",
                    "title": "Network Geo ID",
                    "description": "The raw network-native identifier for this geo target (e.g. Google Ads criterion ID \"21137\", Meta adgeolocation key \"3847\")."
                  },
                  "xdm:resourceName": {
                    "type": "string",
                    "title": "Resource Name",
                    "description": "Fully qualified resource name where applicable (e.g. Google Ads \"geoTargetConstants/21137\")."
                  },
                  "xdm:canonicalName": {
                    "type": "string",
                    "title": "Canonical Name",
                    "description": "Human-readable canonical name as returned by the source network (e.g. \"California, United States\")."
                  },
                  "xdm:resolvedCode": {
                    "type": "string",
                    "title": "Resolved Code",
                    "description": "The normalized ISO code or canonical name this network-native ID was resolved to, cross-referencing an entry in `xdm:countries`, `xdm:regions`, `xdm:cities`, or `xdm:postalCodes`. Omit when resolution is not available."
                  }
                }
              }
            }
          }
        },
        "xdm:demographicTargeting": {
          "type": "object",
          "title": "Demographic Targeting",
          "description": "Demographic targeting specifications",
          "properties": {
            "xdm:ageRanges": {
              "type": "array",
              "title": "Age Ranges",
              "description": "Targeted age ranges",
              "items": {
                "type": "object",
                "properties": {
                  "xdm:minAge": {
                    "type": "integer",
                    "title": "Minimum Age"
                  },
                  "xdm:maxAge": {
                    "type": "integer",
                    "title": "Maximum Age"
                  }
                }
              }
            },
            "xdm:genders": {
              "type": "array",
              "title": "Genders",
              "description": "Targeted genders",
              "items": {
                "type": "string",
                "enum": ["male", "female", "all", "unknown"],
                "meta:enum": {
                  "male": "Male",
                  "female": "Female",
                  "all": "All Genders",
                  "unknown": "Unknown/Unspecified"
                }
              }
            },
            "xdm:languages": {
              "type": "array",
              "title": "Languages",
              "description": "Targeted languages (ISO language codes)",
              "items": {
                "type": "string"
              }
            }
          }
        },
        "xdm:interestTargeting": {
          "type": "object",
          "title": "Interest Targeting",
          "description": "Interest and behavior targeting",
          "properties": {
            "xdm:interests": {
              "type": "array",
              "title": "Interests",
              "description": "Targeted interest categories",
              "items": {
                "type": "string"
              }
            },
            "xdm:behaviors": {
              "type": "array",
              "title": "Behaviors",
              "description": "Targeted behaviors",
              "items": {
                "type": "string"
              }
            },
            "xdm:customAudiences": {
              "type": "array",
              "title": "Custom Audiences",
              "description": "Custom audience segments",
              "items": {
                "type": "object",
                "properties": {
                  "xdm:audienceID": {
                    "type": "string",
                    "title": "Audience ID"
                  },
                  "xdm:audienceName": {
                    "type": "string",
                    "title": "Audience Name"
                  },
                  "xdm:audienceType": {
                    "type": "string",
                    "title": "Audience Type",
                    "enum": [
                      "custom",
                      "lookalike",
                      "retargeting",
                      "similar",
                      "logical",
                      "rule_based",
                      "crm_based"
                    ],
                    "meta:enum": {
                      "custom": "Custom Audience",
                      "lookalike": "Lookalike Audience",
                      "retargeting": "Retargeting Audience (includes Google Ads REMARKETING and EXTERNAL_REMARKETING)",
                      "similar": "Similar Audience",
                      "logical": "Logical Combination Audience (Google Ads)",
                      "rule_based": "Rule-Based Audience (Google Ads)",
                      "crm_based": "CRM-Based Audience (first-party customer data)"
                    }
                  }
                }
              }
            }
          }
        },
        "xdm:deviceTargeting": {
          "type": "object",
          "title": "Device Targeting",
          "description": "Device and platform targeting",
          "properties": {
            "xdm:deviceTypes": {
              "type": "array",
              "title": "Device Types",
              "description": "Targeted device types",
              "items": {
                "type": "string",
                "enum": ["desktop", "mobile", "tablet", "tv", "other"],
                "meta:enum": {
                  "desktop": "Desktop",
                  "mobile": "Mobile",
                  "tablet": "Tablet",
                  "tv": "Connected TV",
                  "other": "Other Device"
                }
              }
            },
            "xdm:operatingSystems": {
              "type": "array",
              "title": "Operating Systems",
              "description": "Targeted operating systems",
              "items": {
                "type": "string"
              }
            },
            "xdm:browsers": {
              "type": "array",
              "title": "Browsers",
              "description": "Targeted browsers",
              "items": {
                "type": "string"
              }
            }
          }
        },
        "xdm:placementTargeting": {
          "type": "object",
          "title": "Placement Targeting",
          "description": "Ad placement targeting",
          "properties": {
            "xdm:placements": {
              "type": "array",
              "title": "Placements",
              "description": "Targeted ad placements",
              "items": {
                "type": "string"
              }
            },
            "xdm:publisherCategories": {
              "type": "array",
              "title": "Publisher Categories",
              "description": "Targeted publisher categories",
              "items": {
                "type": "string"
              }
            }
          }
        }
      }
    }
  },
  "allOf": [
    {
      "$ref": "#/definitions/targeting"
    }
  ],
  "meta:status": "experimental"
}
