  "$id": "https://ns.adobe.com/experience/cvf/alpha-03/cdp/journey",
  "$schema": "http://json-schema.org/draft-06/schema#",
  "title": "Cvf: Alpha03: Journey",
  "description": "AJO journey data.",
  "type": "object",
  "meta:extensible": true,
  "meta:abstract": true,
  "meta:intendedToExtend": [
    "https://ns.adobe.com/xdm/context/experienceevent"
  ],
  "definitions": {
    "journey": {
      "properties": {
        "cvf": {
          "type": "object",
          "properties": {
            "journey": {
              "title": "Journey",
              "description": "Journey id, name, state, aggregate metrics, and per-node entry counts.",
              "type": "object",
              "properties": {
                "id": {
                  "title": "ID",
                  "description": "Journey identifier.",
                  "type": "string"
                },
                "name": {
                  "title": "Name",
                  "type": "string"
                },
                "state": {
                  "title": "State",
                  "description": "Journey lifecycle state (e.g. active).",
                  "type": "string"
                },
                "numEnters": {
                  "title": "Number of Enters",
                  "description": "Number of profile entries into the journey.",
                  "type": "integer",
                  "meta:xdmType": "long",
                  "minimum": 0,
                  "maximum": 9007199254740991
                },
                "numExits": {
                  "title": "Number of Exits",
                  "description": "Number of profile exits from the journey.",
                  "type": "integer",
                  "meta:xdmType": "long",
                  "minimum": 0,
                  "maximum": 9007199254740991
                },
                "numFailures": {
                  "title": "Number of Failures",
                  "description": "Number of journey failures.",
                  "type": "integer",
                  "meta:xdmType": "long",
                  "minimum": 0,
                  "maximum": 9007199254740991
                },
                "numEngagements": {
                  "title": "Number of Engagements",
                  "description": "Number of journey engagements.",
                  "type": "integer",
                  "meta:xdmType": "long",
                  "minimum": 0,
                  "maximum": 9007199254740991
                },
                "nodes": {
                  "title": "Nodes",
                  "description": "Per-node entry statistics.",
                  "type": "array",
                  "meta:xdmType": "array",
                  "items": {
                    "type": "object",
                    "meta:xdmType": "object",
                    "properties": {
                      "name": {
                        "title": "Name",
                        "description": "Node name.",
                        "type": "string"
                      },
                      "numEnters": {
                        "title": "Number of Enters",
                        "description": "Number of profile entries into this node.",
                        "type": "integer",
                        "meta:xdmType": "long",
                        "minimum": 0,
                        "maximum": 9007199254740991
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "allOf": [
    {
      "$ref": "#/definitions/journey"
    }
  ],
  "meta:status": "experimental"
}
