              "type": "object",
              "properties": {
                "id": {
                  "title": "ID",
                  "description": "Campaign identifier.",
                  "type": "string"
                },
                "name": {
                  "title": "Name",
                  "type": "string"
                },
                "numProfiles": {
                  "title": "Num Profiles",
                  "description": "Number of profiles targeted by the campaign.",
                  "type": "integer",
                  "meta:xdmType": "long",
                  "minimum": 0,
                  "maximum": 9007199254740991
                },
                "clickThroughRate": {
                  "title": "Click-Through Rate",
                  "description": "Ratio of clicks to deliveries.",
